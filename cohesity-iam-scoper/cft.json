                                        "arn:aws:s3:::cohesity-ddb*/*"
                                    ]
                                },
                                {
                                    "Action": [
                                        "glue:DeleteJob",
                                        "glue:StartJobRun",
                                        "glue:GetJobRun"
                                    ],
                                    "Condition": {
                                        "StringLike": {
                                            "aws:ResourceTag/UniqueTag": "cohesity_*"
                                        }
                                    },
                                    "Effect": "Allow",
                                    "Resource": "*"
                                },
                                {
                                    "Action": [
                                        "logs:DescribeLogGroups"
                                    ],
                                    "Condition": {
                                        "Ref": "AWS::NoValue"
                                    },
                                    "Effect": "Allow",
                                    "Resource": "arn:aws:logs:*:*:log-group*"
                                },
                                {
                                    "Action": [
                                        "logs:CreateLogGroup",
                                        "logs:CreateLogStream",
                                        "logs:DescribeLogStreams",
                                        "logs:GetLogEvents",
                                        "logs:PutLogEvents",
                                        "logs:PutRetentionPolicy"
                                    ],
                                    "Condition": {
                                        "Ref": "AWS::NoValue"
                                    },
                                    "Effect": "Allow",
                                    "Resource": [
                                        "arn:aws:logs:*:*:log-group:/aws-dynamodb/*",
                                        "arn:aws:logs:*:*:log-group:/aws-glue/*"
                                    ]
                                }
                            ],
                            "Version": "2012-10-17"
                        },
                        "PolicyName": "CohesityDynamoDBPolicy"
                    },
                    {
                        "PolicyDocument": {
                            "Statement": [
                                {
                                    "Action": "rds-db:connect",
                                    "Effect": "Allow",
                                    "Resource": "arn:aws:rds-db:*:*:dbuser:*/*"
                                }
                            ],
                            "Version": "2012-10-17"
                        },
                        "PolicyName": "CohesityRDSDBConnectPolicy"
                    }
                ],
                "RoleName": "CohesitySourceRegistrationRole"
            },
            "Type": "AWS::IAM::Role"
        }
    }
}