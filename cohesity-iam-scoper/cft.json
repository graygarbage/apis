{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Conditions": {
        "ArchiveFlow": {
            "Fn::Or": [
                {
                    "Fn::Equals": [
                        {
                            "Ref": "Workflow"
                        },
                        "external_target"
                    ]
                },
                {
                    "Fn::Equals": [
                        {
                            "Ref": "Workflow"
                        },
                        "both"
                    ]
                }
            ]
        },
        "RestoreFlow": {
            "Fn::Or": [
                {
                    "Fn::Equals": [
                        {
                            "Ref": "Workflow"
                        },
                        "source_registration"
                    ]
                },
                {
                    "Fn::Equals": [
                        {
                            "Ref": "Workflow"
                        },
                        "both"
                    ]
                }
            ]
        },
        "RunningCE": {
            "Fn::Equals": [
                {
                    "Ref": "AccountID"
                },
                {
                    "Ref": "AWS::AccountId"
                }
            ]
        }
    },
    "Metadata": {
        "Copyright": "Copyright 2020 Cohesity Inc."
    },
    "Outputs": {
        "ArchiveWorkflowRoleArn": {
            "Condition": "ArchiveFlow",
            "Description": "The role for archival work flow.",
            "Value": {
                "Fn::GetAtt": [
                    "CohesityArchiveRole",
                    "Arn"
                ]
            }
        },
        "BackupS3StagingRoleArn": {
            "Condition": "RestoreFlow",
            "Description": "The role for AWS services which use s3 buckets as staging location in backup and restore.",
            "Value": {
                "Fn::GetAtt": [
                    "CohesityBackupS3StagingRole",
                    "Arn"
                ]
            }
        },
        "InstanceProfile": {
            "Condition": "RunningCE",
            "Description": "The instance profile that need to be associated with EC2 instance.",
            "Value": {
                "Ref": "CohesityInstanceProfile"
            }
        },
        "RestoreWorkflowRoleArn": {
            "Condition": "RestoreFlow",
            "Description": "The role for restore/cloudspin/CSM/RDS work flow.",
            "Value": {
                "Fn::GetAtt": [
                    "CohesitySourceRegistrationRole",
                    "Arn"
                ]
            }
        }
    },
    "Parameters": {
        "AccountID": {
            "Description": "Enter account id for the account that is running CE.",
            "Type": "Number"
        },
        "Workflow": {
            "AllowedValues": [
                "external_target",
                "source_registration",
                "both"
            ],
            "Default": "external_target",
            "Description": "Enter external_target, source_registration or both. Default is external_target.",
            "Type": "String"
        }
    },
    "Resources": {
        "CohesityArchiveRole": {
            "Condition": "ArchiveFlow",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Statement": [
                        {
                            "Action": [
                                "sts:AssumeRole"
                            ],
                            "Effect": "Allow",
                            "Principal": {
                                "AWS": {
                                    "Fn::If": [
                                        "RunningCE",
                                        {
                                            "Fn::GetAtt": [
                                                "CohesityInstanceRole",
                                                "Arn"
                                            ]
                                        },
                                        {
                                            "Fn::Join": [
                                                ":",
                                                [
                                                    "arn:aws:iam:",
                                                    {
                                                        "Ref": "AccountID"
                                                    },
                                                    "role/CohesityInstanceRole"
                                                ]
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    ],
                    "Version": "2012-10-17"
                },
                "Policies": [
                    {
                        "PolicyDocument": {
                            "Statement": [
                                {
                                    "Action": [
                                        "s3:AbortMultipartUpload",
                                        "s3:DeleteObject",
                                        "s3:DeleteObjectVersion",
                                        "s3:GetObject",
                                        "s3:GetObjectAttributes",
                                        "s3:GetObjectVersion",
                                        "s3:GetObjectVersionAttributes",
                                        "s3:GetLifecycleConfiguration",
                                        "s3:ListMultipartUploadParts",
                                        "s3:PutObject",
                                        "s3:PutObjectRetention",
                                        "s3:RestoreObject"
                                    ],
                                    "Effect": "Allow",
                                    "Resource": [
                                        "arn:aws:s3:::*/*"
                                    ]
                                },
                                {
                                    "Action": [
                                        "s3:GetBucketLocation",
                                        "s3:GetBucketVersioning",
                                        "s3:GetBucketObjectLockConfiguration",
                                        "s3:GetLifecycleConfiguration",
                                        "s3:ListBucket",
                                        "s3:ListBucketMultipartUploads",
                                        "s3:ListBucketVersions",
                                        "s3:GetIntelligentTieringConfiguration",
                                        "kms:GenerateDataKey",
                                        "kms:Decrypt"
                                    ],
                                    "Effect": "Allow",
                                    "Resource": "*"
                                },
                                {
                                    "Action": [
                                        "glacier:InitiateJob",
                                        "glacier:AbortMultipartUpload",
                                        "glacier:DescribeVault",
                                        "glacier:GetJobOutput",
                                        "glacier:DeleteArchive",
                                        "glacier:ListParts",
                                        "glacier:DescribeJob",
                                        "glacier:CompleteMultipartUpload",
                                        "glacier:InitiateMultipartUpload",
                                        "glacier:UploadMultipartPart"
                                    ],
                                    "Effect": "Allow",
                                    "Resource": [
                                        "arn:aws:glacier:*:*:vaults/*"
                                    ]
                                },
                                {
                                    "Action": "glacier:ListProvisionedCapacity",
                                    "Effect": "Allow",
                                    "Resource": "*",
                                    "Sid": "VisualEditor1"
                                }
                            ],
                            "Version": "2012-10-17"
                        },
                        "PolicyName": "external-target-regis-access"
                    }
                ],
                "RoleName": "CohesityArchiveRole"
            },
            "Type": "AWS::IAM::Role"
        },
        "CohesityBackupS3StagingRole": {
            "Condition": "RestoreFlow",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Statement": [
                        {
                            "Action": "sts:AssumeRole",
                            "Effect": "Allow",
                            "Principal": {
                                "Service": [
                                    "rds.amazonaws.com"
                                ]
                            }
                        }
                    ],
                    "Version": "2012-10-17"
                },
                "ManagedPolicyArns": [
                    "arn:aws:iam::aws:policy/service-role/AWSBackupServiceRolePolicyForRestores",
                    "arn:aws:iam::aws:policy/service-role/AWSBackupServiceRolePolicyForBackup"
                ],
                "Policies": [
                    {
                        "PolicyDocument": {
                            "Statement": [
                                {
                                    "Action": [
                                        "s3:ListBucket",
                                        "s3:GetBucketLocation",
                                        "s3:GetObjectAcl",
                                        "s3:GetObjectAttributes",
                                        "s3:GetObject",
                                        "s3:PutObject",
                                        "s3:DeleteObject",
                                        "s3:ListMultipartUploadParts",
                                        "s3:AbortMultipartUpload"
                                    ],
                                    "Effect": "Allow",
                                    "Resource": "arn:aws:s3:::*"
                                }
                            ],
                            "Version": "2012-10-17"
                        },
                        "PolicyName": "BackupS3StagingPolicy"
                    }
                ],
                "RoleName": "CohesityBackupS3StagingRole"
            },
            "Type": "AWS::IAM::Role"
        },
        "CohesityInstanceProfile": {
            "Condition": "RunningCE",
            "Properties": {
                "InstanceProfileName": "CohesityInstanceProfile",
                "Path": "/",
                "Roles": [
                    {
                        "Ref": "CohesityInstanceRole"
                    }
                ]
            },
            "Type": "AWS::IAM::InstanceProfile"
        },
        "CohesityInstanceRole": {
            "Condition": "RunningCE",
            "Properties": {
                "AssumeRolePolicyDocument": {
                    "Statement": [
                        {
                            "Action": [
                                "sts:AssumeRole"
                            ],
                            "Effect": "Allow",
                            "Principal": {
                                "Service": [
                                    "ec2.amazonaws.com"
                                ]
                            }
                        }
                    ],
                    "Version": "2012-10-17"
                },
                "Path": "/",
                "Policies": [
                    {
                        "PolicyDocument": {
                            "Statement": [
                                {
                                    "Action": "sts:AssumeRole",
                                    "Effect": "Allow",
                                    "Resource": "arn:aws:iam::*:role/*"
                                }
                            ],
                            "Version": "2012-10-17"
                        },
                        "PolicyName": "assume-role"
                    }
                ],
                "RoleName": "CohesityInstanceRole"
            },
            "Type": "AWS::IAM::Role"
        },
