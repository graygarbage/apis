  "ec2_vm_backup": {
    "feature_name": "EC2 VM Backup",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups",
      "PUT /v2/data-protect/protection-groups/{id}",
      "GET /v2/data-protect/protection-groups/{id}/runs",
      "POST /v2/data-protect/protection-groups/{id}/runs/actions"
    ],
    "description": "Back up EC2 instances and EBS volumes using native snapshots.",
    "environment_types": ["kAWS", "kAWSNative", "kAWSSnapshotManager"],
    "iam_permissions": {
      "required": [
        "ec2:CopySnapshot",
        "ec2:CreateSnapshot",
        "ec2:CreateTags",
        "ec2:DeleteSnapshot",
        "ec2:DeleteTags",
        "ec2:DescribeAvailabilityZones",
        "ec2:DescribeImages",
        "ec2:DescribeInstanceAttribute",
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus",
        "ec2:DescribeRegions",
        "ec2:DescribeSnapshotAttribute",
        "ec2:DescribeSnapshots",
        "ec2:DescribeTags",
        "ec2:DescribeVolumeAttribute",
        "ec2:DescribeVolumes",
        "ec2:DescribeVolumeStatus",
        "ec2:ModifySnapshotAttribute"
      ],
      "resource_scoping": {
        "ec2:CreateSnapshot": {
          "resource": [
            "arn:aws:ec2:{region}:{account}:volume/*",
            "arn:aws:ec2:{region}::snapshot/*"
          ],
          "condition_keys": ["ec2:ResourceTag/{tag_key}"]
        },
        "ec2:CopySnapshot": {
          "resource": "arn:aws:ec2:{region}::snapshot/*",
          "condition_keys": []
        },
        "ec2:DeleteSnapshot": {
          "resource": "arn:aws:ec2:{region}::snapshot/*",
          "condition_keys": ["ec2:ResourceTag/{tag_key}"]
        },
        "ec2:CreateTags": {
          "resource": [
            "arn:aws:ec2:{region}::snapshot/*",
            "arn:aws:ec2:{region}:{account}:volume/*"
          ],
          "condition_keys": []
        }
      }
    },
    "risk_level": "MEDIUM"
  },

  "ebs_direct_api": {
    "feature_name": "EBS Direct API (Block-Level Backup)",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups",
      "GET /v2/data-protect/protection-groups/{id}/runs"
    ],
    "description": "Use EBS Direct APIs for incremental block-level EC2 volume backups without creating full snapshots.",
    "environment_types": ["kAWS", "kAWSNative"],
    "iam_permissions": {
      "required": [
        "ebs:CompleteSnapshot",
        "ebs:GetSnapshotBlock",
        "ebs:ListChangedBlocks",
        "ebs:ListSnapshotBlocks",
        "ebs:PutSnapshotBlock",
        "ebs:StartSnapshot"
      ],
      "resource_scoping": {
        "ebs:StartSnapshot": {
          "resource": "arn:aws:ec2:{region}::snapshot/*",
          "condition_keys": ["aws:RequestTag/{tag_key}"]
        },
        "ebs:PutSnapshotBlock": {
          "resource": "arn:aws:ec2:{region}::snapshot/*",
          "condition_keys": ["aws:ResourceTag/{tag_key}"]
        }
      }
    },
    "risk_level": "MEDIUM"
  },

