  "iam_role_management": {
    "feature_name": "IAM Role Management",
    "cohesity_apis": [
      "POST /v2/data-protect/sources/registrations",
      "POST /v2/data-protect/external-targets"
    ],
    "description": "Create and manage IAM roles required for cross-account access, archive targets, and CloudSpin.",
    "environment_types": ["kAWS"],
    "iam_permissions": {
      "required": [
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListRoles",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:ListInstanceProfiles",
        "iam:GetInstanceProfile",
        "iam:PassRole",
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:CreateInstanceProfile",
        "iam:DeleteInstanceProfile",
        "iam:AddRoleToInstanceProfile",
        "iam:RemoveRoleFromInstanceProfile",
        "iam:TagRole",
        "iam:UntagRole"
      ],
      "resource_scoping": {
        "iam:CreateRole": {
          "resource": [
            "arn:aws:iam::{account}:role/Cohesity*",
            "arn:aws:iam::{account}:role/cohesity-*"
          ],
          "condition_keys": ["iam:PermissionsBoundary"]
        },
        "iam:DeleteRole": {
          "resource": [
            "arn:aws:iam::{account}:role/Cohesity*",
            "arn:aws:iam::{account}:role/cohesity-*"
          ],
          "condition_keys": []
        },
        "iam:PutRolePolicy": {
          "resource": [
            "arn:aws:iam::{account}:role/Cohesity*",
            "arn:aws:iam::{account}:role/cohesity-*"
          ],
          "condition_keys": []
        },
        "iam:AttachRolePolicy": {
          "resource": [
            "arn:aws:iam::{account}:role/Cohesity*",
            "arn:aws:iam::{account}:role/cohesity-*"
          ],
          "condition_keys": []
        },
        "iam:PassRole": {
          "resource": [
            "arn:aws:iam::{account}:role/Cohesity*",
            "arn:aws:iam::{account}:role/cohesity-*"
          ],
          "condition_keys": ["iam:PassedToService"]
        }
      }
    },
    "risk_level": "HIGH"
  },

  "ssm_operations": {
    "feature_name": "SSM Operations (App-Consistent Backups)",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups",
      "PUT /v2/data-protect/protection-groups/{id}"
    ],
    "description": "Use AWS Systems Manager to quiesce applications for app-consistent EC2 snapshots.",
    "environment_types": ["kAWS", "kAWSNative"],
    "iam_permissions": {
      "required": [
        "ssm:DescribeInstanceInformation",
        "ssm:ListCommandInvocations",
        "ssm:GetCommandInvocation",
        "ssm:DescribeDocument",
        "ssm:ListDocuments",
        "ssm:SendCommand"
      ],
      "resource_scoping": {
        "ssm:SendCommand": {
          "resource": [
            "arn:aws:ssm:{region}::document/AWS-RunShellScript",
            "arn:aws:ssm:{region}::document/AWS-RunPowerShellScript",
            "arn:aws:ssm:{region}:{account}:document/CohesityBackup*",
            "arn:aws:ec2:{region}:{account}:instance/*"
          ],
          "condition_keys": ["ssm:resourceTag/CohesityManaged"]
        }
      }
    },
    "risk_level": "MEDIUM"
  },

