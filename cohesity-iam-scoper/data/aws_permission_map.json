{
  "ec2_vm_backup": {
    "feature_name": "EC2 VM Backup",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups",
      "PUT /v2/data-protect/protection-groups/{id}",
      "GET /v2/data-protect/protection-groups/{id}/runs",
      "POST /v2/data-protect/protection-groups/{id}/runs/actions"
    ],
    "description": "Back up EC2 instances and EBS volumes using native snapshots.",
    "environment_types": ["kAWS", "kAWSNative", "kAWSSnapshotManager"],
    "iam_permissions": {
      "required": [
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus",
        "ec2:DescribeVolumes",
        "ec2:DescribeVolumeStatus",
        "ec2:DescribeSnapshots",
        "ec2:DescribeSnapshotAttribute",
        "ec2:DescribeTags",
        "ec2:DescribeImages",
        "ec2:DescribeRegions",
        "ec2:DescribeAvailabilityZones",
        "ec2:CreateSnapshot",
        "ec2:CopySnapshot",
        "ec2:DeleteSnapshot",
        "ec2:CreateTags",
        "ec2:DeleteTags"
      ],
      "resource_scoping": {
        "ec2:CreateSnapshot": {
          "resource": "arn:aws:ec2:{region}:{account}:volume/*",
          "condition_keys": ["ec2:ResourceTag/CohesityManaged"]
        },
        "ec2:CopySnapshot": {
          "resource": "arn:aws:ec2:{region}::snapshot/*",
          "condition_keys": []
        },
        "ec2:DeleteSnapshot": {
          "resource": "arn:aws:ec2:{region}::snapshot/*",
          "condition_keys": ["ec2:ResourceTag/CohesityManaged"]
        },
        "ec2:CreateTags": {
          "resource": [
            "arn:aws:ec2:{region}::snapshot/*",
            "arn:aws:ec2:{region}:{account}:volume/*"
          ],
          "condition_keys": []
        }
      }
    },
    "risk_level": "MEDIUM"
  },

  "ec2_vm_restore": {
    "feature_name": "EC2 VM Restore / CloudSpin",
    "cohesity_apis": [
      "POST /v2/data-protect/recoveries",
      "GET /v2/data-protect/recoveries/{id}",
      "POST /v2/data-protect/recoveries/{id}/cancel"
    ],
    "description": "Restore EC2 instances and EBS volumes from Cohesity snapshots or cloud-spin to AWS.",
    "environment_types": ["kAWS", "kAWSNative"],
    "iam_permissions": {
      "required": [
        "ec2:DescribeInstances",
        "ec2:DescribeImages",
        "ec2:DescribeSnapshots",
        "ec2:DescribeVolumes",
        "ec2:DescribeSubnets",
        "ec2:DescribeVpcs",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeKeyPairs",
        "ec2:DescribeInstanceTypes",
        "ec2:RunInstances",
        "ec2:StartInstances",
        "ec2:StopInstances",
        "ec2:TerminateInstances",
        "ec2:CreateVolume",
        "ec2:AttachVolume",
        "ec2:DetachVolume",
        "ec2:DeleteVolume",
        "ec2:RegisterImage",
        "ec2:DeregisterImage",
        "ec2:CreateTags",
        "ec2:DeleteTags",
        "ec2:ModifyInstanceAttribute",
        "ec2:ModifyVolumeAttribute"
      ],
      "resource_scoping": {
        "ec2:RunInstances": {
          "resource": [
            "arn:aws:ec2:{region}:{account}:instance/*",
            "arn:aws:ec2:{region}:{account}:volume/*",
            "arn:aws:ec2:{region}:{account}:network-interface/*",
            "arn:aws:ec2:{region}:{account}:subnet/{subnet_ids}",
            "arn:aws:ec2:{region}:{account}:security-group/*",
            "arn:aws:ec2:{region}::image/*",
            "arn:aws:ec2:{region}:{account}:key-pair/*"
          ],
          "condition_keys": ["aws:RequestTag/CohesityManaged"]
        },
        "ec2:TerminateInstances": {
          "resource": "arn:aws:ec2:{region}:{account}:instance/*",
          "condition_keys": ["ec2:ResourceTag/CohesityManaged"]
        },
        "ec2:CreateVolume": {
          "resource": "arn:aws:ec2:{region}:{account}:volume/*",
          "condition_keys": ["aws:RequestTag/CohesityManaged"]
        }
      }
    },
    "risk_level": "HIGH"
  },

  "rds_backup": {
    "feature_name": "RDS Backup",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups",
      "PUT /v2/data-protect/protection-groups/{id}",
      "GET /v2/data-protect/protection-groups/{id}/runs"
    ],
    "description": "Back up RDS DB instances and Aurora clusters using native RDS snapshots.",
    "environment_types": [
      "kRDSSnapshotManager",
      "kRDSPostgresSnapshotManager",
      "kRDSMySQLSnapshotManager",
      "kAuroraSnapshotManager",
      "kAWSMySQL",
      "kAWSRdsOracle",
      "kAWSRDSPostgresDB",
      "kAWSRDSMSSQL"
    ],
    "iam_permissions": {
      "required": [
        "rds:DescribeDBInstances",
        "rds:DescribeDBClusters",
        "rds:DescribeDBSnapshots",
        "rds:DescribeDBClusterSnapshots",
        "rds:DescribeDBSubnetGroups",
        "rds:DescribeDBParameterGroups",
        "rds:DescribeDBClusterParameterGroups",
        "rds:DescribeOptionGroups",
        "rds:ListTagsForResource",
        "rds:CreateDBSnapshot",
        "rds:CopyDBSnapshot",
        "rds:DeleteDBSnapshot",
        "rds:CreateDBClusterSnapshot",
        "rds:CopyDBClusterSnapshot",
        "rds:DeleteDBClusterSnapshot",
        "rds:AddTagsToResource",
        "rds:RemoveTagsFromResource"
      ],
      "resource_scoping": {
        "rds:CreateDBSnapshot": {
          "resource": [
            "arn:aws:rds:{region}:{account}:db:*",
            "arn:aws:rds:{region}:{account}:snapshot:cohesity-*"
          ],
          "condition_keys": []
        },
        "rds:DeleteDBSnapshot": {
          "resource": "arn:aws:rds:{region}:{account}:snapshot:cohesity-*",
          "condition_keys": []
        },
        "rds:CreateDBClusterSnapshot": {
          "resource": [
            "arn:aws:rds:{region}:{account}:cluster:*",
            "arn:aws:rds:{region}:{account}:cluster-snapshot:cohesity-*"
          ],
          "condition_keys": []
        },
        "rds:DeleteDBClusterSnapshot": {
          "resource": "arn:aws:rds:{region}:{account}:cluster-snapshot:cohesity-*",
          "condition_keys": []
        }
      }
    },
    "risk_level": "MEDIUM"
  },

  "rds_restore": {
