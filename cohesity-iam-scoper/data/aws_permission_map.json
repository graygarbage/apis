  "rds_backup": {
    "feature_name": "RDS Backup",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups",
      "PUT /v2/data-protect/protection-groups/{id}",
      "GET /v2/data-protect/protection-groups/{id}/runs"
    ],
    "description": "Back up RDS DB instances and Aurora clusters using native RDS snapshots.",
    "environment_types": [
      "kRDSSnapshotManager",
      "kRDSPostgresSnapshotManager",
      "kRDSMySQLSnapshotManager",
      "kAuroraSnapshotManager",
      "kAWSMySQL",
      "kAWSRdsOracle",
      "kAWSRDSPostgresDB",
      "kAWSRDSMSSQL"
    ],
    "iam_permissions": {
      "required": [
        "rds:AddTagsToResource",
        "rds:CopyDBClusterSnapshot",
        "rds:CopyDBSnapshot",
        "rds:CreateDBClusterSnapshot",
        "rds:CreateDBSnapshot",
        "rds:DeleteDBClusterSnapshot",
        "rds:DeleteDBSnapshot",
        "rds:DescribeDBClusterSnapshots",
        "rds:DescribeDBClusters",
        "rds:DescribeDBInstances",
        "rds:DescribeDBParameterGroups",
        "rds:DescribeDBSnapshots",
        "rds:DescribeDBSubnetGroups",
        "rds:DescribeOptionGroups",
        "rds:DescribeSourceRegions",
        "rds:DescribeTenantDatabases",
        "rds:ListTagsForResource",
        "rds:ModifyDBClusterSnapshotAttribute",
        "rds:ModifyDBSnapshotAttribute"
      ],
      "resource_scoping": {
        "rds:CreateDBSnapshot": {
          "resource": [
            "arn:aws:rds:{region}:{account}:db:*",
            "arn:aws:rds:{region}:{account}:snapshot:{snapshot_prefix}*"
          ],
          "condition_keys": []
        },
        "rds:DeleteDBSnapshot": {
          "resource": "arn:aws:rds:{region}:{account}:snapshot:{snapshot_prefix}*",
          "condition_keys": []
        },
        "rds:CreateDBClusterSnapshot": {
          "resource": [
            "arn:aws:rds:{region}:{account}:cluster:*",
            "arn:aws:rds:{region}:{account}:cluster-snapshot:{snapshot_prefix}*"
          ],
          "condition_keys": []
        },
        "rds:DeleteDBClusterSnapshot": {
          "resource": "arn:aws:rds:{region}:{account}:cluster-snapshot:{snapshot_prefix}*",
          "condition_keys": []
        }
      }
    },
    "risk_level": "MEDIUM"
  },

  "rds_restore": {
    "feature_name": "RDS Restore",
    "cohesity_apis": [
      "POST /v2/data-protect/recoveries",
      "GET /v2/data-protect/recoveries/{id}"
    ],
    "description": "Restore RDS DB instances and Aurora clusters from snapshots, including point-in-time recovery.",
    "environment_types": [
      "kRDSSnapshotManager",
      "kAuroraSnapshotManager",
      "kAWSRDSPostgresDB",
      "kAWSRDSMSSQL"
    ],
    "iam_permissions": {
      "required": [
        "rds:AddTagsToResource",
        "rds:CreateDBInstance",
        "rds:DescribeDBClusterSnapshots",
        "rds:DescribeDBClusters",
        "rds:DescribeDBInstances",
        "rds:DescribeDBParameterGroups",
        "rds:DescribeDBSnapshots",
        "rds:DescribeDBSubnetGroups",
        "rds:DescribeOptionGroups",
        "rds:ListTagsForResource",
        "rds:RestoreDBClusterFromSnapshot",
        "rds:RestoreDBInstanceFromDBSnapshot",
        "rds:RestoreDBInstanceToPointInTime"
      ],
      "resource_scoping": {
        "rds:RestoreDBInstanceFromDBSnapshot": {
          "resource": [
            "arn:aws:rds:{region}:{account}:db:*",
            "arn:aws:rds:{region}:{account}:snapshot:{snapshot_prefix}*"
          ],
          "condition_keys": []
        },
        "rds:RestoreDBClusterFromSnapshot": {
          "resource": [
            "arn:aws:rds:{region}:{account}:cluster:*",
            "arn:aws:rds:{region}:{account}:cluster-snapshot:{snapshot_prefix}*"
          ],
          "condition_keys": []
        }
      }
    },
    "risk_level": "HIGH"
  },

  "rds_db_connect": {
    "feature_name": "RDS DB Connect (IAM Auth)",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups"
    ],
    "description": "Connect to RDS databases using IAM authentication for application-aware backups.",
    "environment_types": ["kAWSRDSPostgresDB", "kAWSRDSMSSQL", "kAWSMySQL"],
    "iam_permissions": {
      "required": [
        "rds-db:connect"
      ],
      "resource_scoping": {
        "rds-db:connect": {
          "resource": "arn:aws:rds-db:{region}:{account}:dbuser:*/*",
          "condition_keys": []
        }
      }
    },
    "risk_level": "MEDIUM"
  },

  "rds_staging_s3": {
    "feature_name": "RDS Backup S3 Staging",
    "cohesity_apis": [
      "POST /v2/data-protect/protection-groups",
      "GET /v2/data-protect/protection-groups/{id}/runs"
    ],
    "description": "Stage RDS backup data through S3 during cross-region or cross-account restore operations.",
    "environment_types": ["kRDSSnapshotManager", "kAuroraSnapshotManager"],
    "iam_permissions": {
      "required": [
        "s3:AbortMultipartUpload",
        "s3:DeleteObject",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:GetObjectAcl",
        "s3:GetObjectAttributes",
        "s3:ListBucket",
        "s3:ListMultipartUploadParts",
        "s3:PutObject"
      ],
      "managed_policies": [
        "arn:aws:iam::aws:policy/service-role/AWSBackupServiceRolePolicyForRestores",
        "arn:aws:iam::aws:policy/service-role/AWSBackupServiceRolePolicyForBackup"
      ],
      "resource_scoping": {
        "s3:GetObject": {
          "resource": "arn:aws:s3:::*",
          "condition_keys": []
        },
        "s3:PutObject": {
          "resource": "arn:aws:s3:::*",
          "condition_keys": []
        }
      },
      "trust_policy_principals": ["rds.amazonaws.com"]
    },
    "risk_level": "MEDIUM"
  },

