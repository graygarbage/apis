{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Cohesity Cloud Edition - Minimal Scoped IAM Roles (generated by cohesity-iam-scoper)",
  "Parameters": {
    "CohesityTagKey": {
      "Type": "String",
      "Default": "CohesityManaged",
      "Description": "Tag key applied to all Cohesity-managed resources"
    },
    "CohesityTagValue": {
      "Type": "String",
      "Default": "true",
      "Description": "Tag value applied to all Cohesity-managed resources"
    },
    "AllowedRegions": {
      "Type": "CommaDelimitedList",
      "Default": "us-east-1",
      "Description": "Comma-separated list of AWS regions where Cohesity operates"
    },
    "ArchiveBucketPattern": {
      "Type": "String",
      "Default": "cohesity-archive-*",
      "Description": "S3 bucket name pattern for Cohesity archive buckets"
    }
  },
  "Resources": {
    "CohesitySourceRegistrationRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "CohesitySourceRegistrationRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": { "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root" }
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "CohesitySourceDiscovery",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "EC2DiscoveryReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "ec2:DescribeInstances",
                    "ec2:DescribeInstanceStatus",
                    "ec2:DescribeVolumes",
                    "ec2:DescribeVolumeStatus",
                    "ec2:DescribeSnapshots",
                    "ec2:DescribeImages",
                    "ec2:DescribeRegions",
                    "ec2:DescribeAvailabilityZones",
                    "ec2:DescribeVpcs",
                    "ec2:DescribeSubnets",
                    "ec2:DescribeSecurityGroups",
                    "ec2:DescribeNetworkInterfaces",
                    "ec2:DescribeKeyPairs",
                    "ec2:DescribeTags",
                    "ec2:DescribeInternetGateways",
                    "ec2:DescribeRouteTables"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "RDSDiscoveryReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "rds:DescribeDBInstances",
                    "rds:DescribeDBClusters",
                    "rds:DescribeDBSubnetGroups",
                    "rds:ListTagsForResource"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "S3DiscoveryReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "s3:ListAllMyBuckets",
                    "s3:GetBucketLocation",
                    "s3:GetBucketTagging"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "DynamoDBDiscoveryReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:ListTables",
                    "dynamodb:DescribeTable",
                    "dynamodb:ListTagsOfResource"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "IAMDiscoveryReadOnly",
                  "Effect": "Allow",
                  "Action": [
                    "iam:GetUser",
                    "iam:GetAccountSummary",
                    "iam:ListAccountAliases"
                  ],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      }
    },

    "CohesityArchiveRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "CohesityArchiveRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": { "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root" }
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "CohesityS3ArchiveAccess",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "S3ArchiveBucketList",
                  "Effect": "Allow",
                  "Action": [
                    "s3:ListAllMyBuckets",
                    "s3:GetBucketLocation"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "S3ArchiveBucketOperations",
                  "Effect": "Allow",
                  "Action": [
                    "s3:ListBucket",
                    "s3:GetBucketVersioning",
                    "s3:GetBucketObjectLockConfiguration",
                    "s3:GetBucketPolicy",
                    "s3:GetBucketAcl",
                    "s3:GetLifecycleConfiguration",
                    "s3:GetEncryptionConfiguration",
                    "s3:ListBucketMultipartUploads",
                    "s3:ListBucketVersions"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:aws:s3:::${ArchiveBucketPattern}"
                  }
                },
                {
                  "Sid": "S3ArchiveObjectOperations",
                  "Effect": "Allow",
                  "Action": [
                    "s3:GetObject",
                    "s3:GetObjectVersion",
                    "s3:GetObjectTagging",
                    "s3:GetObjectAcl",
                    "s3:PutObject",
                    "s3:PutObjectTagging",
                    "s3:PutObjectAcl",
                    "s3:DeleteObject",
                    "s3:DeleteObjectVersion",
                    "s3:AbortMultipartUpload"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:aws:s3:::${ArchiveBucketPattern}/*"
                  }
                }
              ]
            }
          }
        ]
      }
    },

    "CohesityBackupRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "CohesityBackupRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": { "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root" }
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "CohesityEC2SnapshotOperations",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "EC2SnapshotCreate",
                  "Effect": "Allow",
                  "Action": [
                    "ec2:CreateSnapshot",
                    "ec2:CopySnapshot"
                  ],
                  "Resource": [
                    { "Fn::Sub": "arn:aws:ec2:*:${AWS::AccountId}:volume/*" },
                    "arn:aws:ec2:*::snapshot/*"
                  ],
                  "Condition": {
                    "StringEquals": {
                      "aws:RequestTag/CohesityManaged": { "Ref": "CohesityTagValue" }
                    }
                  }
                },
                {
                  "Sid": "EC2SnapshotDelete",
                  "Effect": "Allow",
                  "Action": "ec2:DeleteSnapshot",
                  "Resource": "arn:aws:ec2:*::snapshot/*",
                  "Condition": {
                    "StringEquals": {
                      "ec2:ResourceTag/CohesityManaged": { "Ref": "CohesityTagValue" }
                    }
                  }
                },
                {
                  "Sid": "EC2TaggingCohesityResources",
                  "Effect": "Allow",
                  "Action": [
                    "ec2:CreateTags",
                    "ec2:DeleteTags"
                  ],
                  "Resource": [
                    "arn:aws:ec2:*::snapshot/*",
                    { "Fn::Sub": "arn:aws:ec2:*:${AWS::AccountId}:volume/*" }
                  ]
                }
              ]
            }
          }
        ]
      }
    }
  },

  "Outputs": {
    "SourceRegistrationRoleArn": {
      "Value": { "Fn::GetAtt": ["CohesitySourceRegistrationRole", "Arn"] },
      "Description": "ARN of the Cohesity Source Registration Role"
    },
    "ArchiveRoleArn": {
      "Value": { "Fn::GetAtt": ["CohesityArchiveRole", "Arn"] },
      "Description": "ARN of the Cohesity Archive Role"
    },
    "BackupRoleArn": {
      "Value": { "Fn::GetAtt": ["CohesityBackupRole", "Arn"] },
      "Description": "ARN of the Cohesity Backup Role"
    }
  }
}
